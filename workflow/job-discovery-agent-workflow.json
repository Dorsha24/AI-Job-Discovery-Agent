    {
      "parameters": {
        "jsCode": "const aiItems = $input.all();\nconst jobItems = $(\"Clean Results\").all();\n\nconst results = [];\n\nfor (let i = 0; i < jobItems.length; i++) {\n  const job = jobItems[i].json;\n  const aiItem = aiItems[i]?.json;\n\n  let company = {};\n\n  if (aiItem && !aiItem.error) {\n    const text = aiItem.output?.[0]?.content?.[0]?.text;\n\n    if (text) {\n      try {\n        company = JSON.parse(text);\n      } catch (e) {\n        company = {};\n      }\n    }\n  }\n\n  results.push({\n    json: {\n      ...job,\n      \"Company Summary\": company.company_summary || \"Unknown\",\n      \"Industry\": company.industry || \"Unknown\",\n      \"Company Size\": company.company_size || \"Unknown\",\n      \"Funding\": company.funding || \"Unknown\",\n      \"HQ\": company.hq || \"Unknown\",\n      \"Company Fit\": company.company_fit || \"Unknown\"\n    }\n  });\n}\n\nreturn results;"
      },
