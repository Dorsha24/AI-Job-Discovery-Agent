      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst topJobs = items\n  .sort((a, b) => (b.json[\"Match Score\"] || 0) - (a.json[\"Match Score\"] || 0))\n  .slice(0, 5);\n\nlet message = `🚀 Top 5 Job Matches Today\\n\\n`;\n\nfor (const item of topJobs) {\n  const job = item.json;\n\n  message += `*${job[\"Job Title\"]}*\\n`;\n  message += `Company: ${job[\"Company\"]}\\n`;\n  message += `Score: ${job[\"Match Score\"]}\\n`;\n  message += `Priority: ${job[\"Priority\"]}\\n`;\n  message += `Link: ${job[\"Job URL\"]}\\n\\n`;\n}\n\nreturn [{ json: { message } }];"
      },
