        "jsCode": "const items = $input.all();\nconst seenUrls = new Set();\nconst cleaned = [];\n\nfor (const item of items) {\n  const url = item.json[\"Job URL\"];\n\n  if (!url) continue;\n  if (seenUrls.has(url)) continue;\n\n  seenUrls.add(url);\n  cleaned.push(item);\n}\n\nreturn cleaned;"
