    {
      "parameters": {
        "jsCode": "const aiItems = $input.all();\nconst jobItems = $(\"Merge\").all();\n\nconst results = [];\n\nfor (let i = 0; i < aiItems.length; i++) {\n  const aiItem = aiItems[i].json;\n  const job = jobItems[i]?.json;\n\n  if (!job) continue;\n\n  // Skip failed GPT items\n  if (aiItem.error) continue;\n\n  const text = aiItem.output?.[0]?.content?.[0]?.text;\n\n  if (!text) continue;\n\n  let ai;\n\n  try {\n    ai = JSON.parse(text);\n  } catch (e) {\n    continue;\n  }\n\n  results.push({\n    json: {\n      Date: new Date().toISOString().split(\"T\")[0],\n      \"Job Title\": job.title,\n      Company: job.company_name,\n      Location: job.location?.name || \"\",\n      \"Job URL\": job.absolute_url,\n      Source: \"Greenhouse\",\n      \"Match Score\": ai.score,\n      Category: ai.category,\n      Apply: ai.apply,\n      Reason: ai.reason,\n      Priority: ai.priority,\n      \"Missing Skills\": ai.missing_skills\n    }\n  });\n}\n\nreturn results;"
      },
